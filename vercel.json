{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix reseller-system/frontend install",
  "buildCommand": "npm --prefix reseller-system/frontend run build",
  "outputDirectory": "reseller-system/frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}